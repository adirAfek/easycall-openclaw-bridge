# Cursor Cloud Agents
CURSOR_API_KEY=cur_xxx
CURSOR_WEBHOOK_SECRET=replace-with-32-byte-random-secret
CURSOR_WEBHOOK_URL=https://claw.example.com/hooks/cursor
# Cursor v1 webhook field is beta. Keep default unless Cursor changes the API.
CURSOR_CREATE_AGENT_WEBHOOK_FIELD=webhookUrl
# Optional explicit model id from GET /v1/models.
# CURSOR_MODEL_ID=claude-4-sonnet-thinking

# EasyCall repository
EASYCALL_REPO_URL=https://github.com/your-org/EasyCall
EASYCALL_STARTING_REF=main

# OpenClaw WhatsApp owner notification
# Optional. If omitted, Cursor webhook results are logged instead of sent by WhatsApp.
# EASYCALL_OWNER_WAID=+972501234567
# OPENCLAW_WHATSAPP_ACCOUNT=default
OPENCLAW_BIN=openclaw

# Manual EasyCall voice QA
EASYCALL_PRODUCTION_NUMBER=+972765993143
# Optional, if using a dedicated Twilio caller number in OpenClaw voice-call.
# EASYCALL_QA_CALLER_NUMBER=+15551234567
EASYCALL_QA_MAX_DURATION_SECONDS=180
# log or whatsapp. Start with log until WhatsApp owner notifications are configured.
EASYCALL_QA_NOTIFY_MODE=log

# Fallback state file if OpenClaw runtime state is not available to external plugins.
OPENCLAW_BRIDGE_STATE_PATH=/home/openclaw/.openclaw/easycall-cursor-bridge/state.json
